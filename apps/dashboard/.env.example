# ── Network ────────────────────────────────────────────────────────────────────
# Canonical selector (sepolia | mainnet | 0gTestnet | 0gMainnet)
NEXT_PUBLIC_NETWORK=0gTestnet
RPC_URL=https://evmrpc-testnet.0g.ai

# ── Deployed Contracts ─────────────────────────────────────────────────────────
# Auto-fill with: npm run setup-env --prefix contracts [chainId]
AGENT_REGISTRY_ADDRESS=
ENS_AGENT_REGISTRY_ADDRESS=
REPUTATION_REGISTRY_ADDRESS=
VALIDATION_REGISTRY_ADDRESS=
NEXT_PUBLIC_TEE_VERIFIER_ADDRESS=

# ── ENS Relayer (client-visible) ──────────────────────────────────────────────
# ENS chain is inferred from NEXT_PUBLIC_NETWORK:
# - sepolia / testnet => ENS checks on Sepolia
# - mainnet => ENS checks on Mainnet
# Client-visible ENS registry address for that chain.
NEXT_PUBLIC_ENS_REGISTRY_ADDRESS=0x00000000000C2E074eC69A0dFb2997BA6C7d2e1e

# Optional. If empty, UI skips ENS relayer approval check.
NEXT_PUBLIC_ENS_RELAYER_ADDRESS=

# ── Deployer key (server-side only — never expose publicly) ───────────────────
PRIVATE_KEY=

# ── Oracle ────────────────────────────────────────────────────────────────────
ORACLE_PRIVATE_KEY=
# Optional override. If omitted, the dashboard derives this from ORACLE_PRIVATE_KEY.
TEE_ENCRYPTION_PUBLIC_KEY=