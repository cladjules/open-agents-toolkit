# ── Network ───────────────────────────────────────────────────────────────────
# Target network for deployment scripts:
#   sepolia    → npm run deploy:sepolia
#   0gTestnet  → npm run deploy:zeroG
# (mainnet / 0gMainnet variants use --network mainnet / --network zeroGMainnet)
NETWORK=sepolia

# ── Deployer key ──────────────────────────────────────────────────────────────
# 0x-prefixed hex private key used for all deployments.
# Per-network overrides below take precedence when set.
PRIVATE_KEY=

# ── Sepolia testnet ───────────────────────────────────────────────────────────
# RPC endpoint (optional — defaults to https://rpc.sepolia.org)
SEPOLIA_RPC_URL=
SEPOLIA_PRIVATE_KEY=

# ── 0G Galileo testnet (Chain ID 16602) ───────────────────────────────────────
# Public RPC: https://evmrpc-testnet.0g.ai (pre-filled)
# Get testnet tokens: https://faucet.0g.ai
# Explorer: https://chainscan-galileo.0g.ai
ZERO_G_RPC_URL=https://evmrpc-testnet.0g.ai
ZERO_G_PRIVATE_KEY=
