{
  "name": "@open-agents-toolkit/contracts",
  "version": "0.1.0",
  "description": "Solidity contracts for the open-agents-toolkit (ERC-8004, ERC-7857)",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "hardhat build",
    "test": "hardhat test",
    "test:node": "hardhat test nodejs",
    "clean": "hardhat clean",
    "node": "hardhat node",
    "deploy:sepolia": "hardhat ignition deploy ignition/modules/Deploy.ts --network sepolia",
    "deploy:zeroG": "hardhat ignition deploy ignition/modules/Deploy.ts --network zeroGGalileo",
    "addOracle:sepolia": "hardhat ignition deploy ignition/modules/AddOracle.ts --network sepolia",
    "addOracle:zeroG": "hardhat ignition deploy ignition/modules/AddOracle.ts --network zeroGGalileo --parameters ignition/parameters.zeroG.json --reset",
    "oracle:start": "node --import tsx/esm scripts/oracle-server.ts",
    "e2e:zeroG": "node --import tsx/esm scripts/e2e.ts"
  },
  "devDependencies": {
    "@open-agents-toolkit/compute": "file:../packages/compute",
    "@nomicfoundation/hardhat-ignition": "^3.1.3",
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.4",
    "@openzeppelin/contracts": "^5.6.1",
    "@types/node": "^22.19.17",
    "dotenv": "^17.4.2",
    "forge-std": "github:foundry-rs/forge-std#v1.9.4",
    "hardhat": "^3.4.1",
    "typescript": "~5.8.0",
    "viem": "^2.48.4"
  }
}
